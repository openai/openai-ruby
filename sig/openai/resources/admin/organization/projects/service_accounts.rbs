module OpenAI
  module Resources
    class Admin
      class Organization
        class Projects
          class ServiceAccounts
            def create: (
              String project_id,
              name: String,
              ?request_options: OpenAI::request_opts
            ) -> OpenAI::Models::Admin::Organization::Projects::ServiceAccountCreateResponse

            def retrieve: (
              String service_account_id,
              project_id: String,
              ?request_options: OpenAI::request_opts
            ) -> OpenAI::Admin::Organization::Projects::ProjectServiceAccount

            def update: (
              String service_account_id,
              project_id: String,
              ?name: String,
              ?role: OpenAI::Models::Admin::Organization::Projects::ServiceAccountUpdateParams::role,
              ?request_options: OpenAI::request_opts
            ) -> OpenAI::Admin::Organization::Projects::ProjectServiceAccount

            def list: (
              String project_id,
              ?after: String,
              ?limit: Integer,
              ?request_options: OpenAI::request_opts
            ) -> OpenAI::Internal::ConversationCursorPage[OpenAI::Admin::Organization::Projects::ProjectServiceAccount]

            def delete: (
              String service_account_id,
              project_id: String,
              ?request_options: OpenAI::request_opts
            ) -> OpenAI::Models::Admin::Organization::Projects::ServiceAccountDeleteResponse

            def initialize: (client: OpenAI::Client) -> void
          end
        end
