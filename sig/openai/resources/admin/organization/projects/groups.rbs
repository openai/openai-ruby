            ) -> OpenAI::Admin::Organization::Projects::ProjectGroup

            def list: (
              String project_id,
              ?after: String,
              ?limit: Integer,
              ?order: OpenAI::Models::Admin::Organization::Projects::GroupListParams::order,
              ?request_options: OpenAI::request_opts
            ) -> OpenAI::Internal::NextCursorPage[OpenAI::Admin::Organization::Projects::ProjectGroup]

            def delete: (
