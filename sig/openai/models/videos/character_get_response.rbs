module OpenAI
  module Models
    module Videos
      type character_get_response =
        { id: String?, created_at: Integer, name: String? }

      class CharacterGetResponse < OpenAI::Internal::Type::BaseModel
        attr_accessor id: String?

        attr_accessor created_at: Integer

        attr_accessor name: String?

        def initialize: (
          id: String?,
          created_at: Integer,
          name: String?
        ) -> void

        def to_hash: -> { id: String?, created_at: Integer, name: String? }
      end
    end
  end
end
