module OpenAI
  module Models
    class BetaResponseCompletedEvent = Beta::BetaResponseCompletedEvent

    module Beta
      type beta_response_completed_event =
        {
          response: OpenAI::Beta::BetaResponse,
          sequence_number: Integer,
          type: :"response.completed",
          agent: OpenAI::Beta::BetaResponseCompletedEvent::Agent?
        }

      class BetaResponseCompletedEvent < OpenAI::Internal::Type::BaseModel
        attr_accessor response: OpenAI::Beta::BetaResponse

        attr_accessor sequence_number: Integer

        attr_accessor type: :"response.completed"

        attr_accessor agent: OpenAI::Beta::BetaResponseCompletedEvent::Agent?

        def initialize: (
          response: OpenAI::Beta::BetaResponse,
          sequence_number: Integer,
          ?agent: OpenAI::Beta::BetaResponseCompletedEvent::Agent?,
          ?type: :"response.completed"
        ) -> void

        def to_hash: -> {
          response: OpenAI::Beta::BetaResponse,
          sequence_number: Integer,
          type: :"response.completed",
          agent: OpenAI::Beta::BetaResponseCompletedEvent::Agent?
        }

        type agent = { agent_name: String }

        class Agent < OpenAI::Internal::Type::BaseModel
          attr_accessor agent_name: String

          def initialize: (agent_name: String) -> void

          def to_hash: -> { agent_name: String }
        end
      end
    end
  end
end
