module OpenAI
  module Models
    class BetaResponseReasoningItem = Beta::BetaResponseReasoningItem

    module Beta
      type beta_response_reasoning_item =
        {
          id: String,
          summary: ::Array[OpenAI::Beta::BetaResponseReasoningItem::Summary],
          type: :reasoning,
          agent: OpenAI::Beta::BetaResponseReasoningItem::Agent?,
          content: ::Array[OpenAI::Beta::BetaResponseReasoningItem::Content],
          encrypted_content: String?,
          status: OpenAI::Models::Beta::BetaResponseReasoningItem::status
        }

      class BetaResponseReasoningItem < OpenAI::Internal::Type::BaseModel
        attr_accessor id: String

        attr_accessor summary: ::Array[OpenAI::Beta::BetaResponseReasoningItem::Summary]

        attr_accessor type: :reasoning

        attr_accessor agent: OpenAI::Beta::BetaResponseReasoningItem::Agent?

        attr_reader content: ::Array[OpenAI::Beta::BetaResponseReasoningItem::Content]?

        def content=: (
          ::Array[OpenAI::Beta::BetaResponseReasoningItem::Content]
        ) -> ::Array[OpenAI::Beta::BetaResponseReasoningItem::Content]

        attr_accessor encrypted_content: String?

        attr_reader status: OpenAI::Models::Beta::BetaResponseReasoningItem::status?

        def status=: (
          OpenAI::Models::Beta::BetaResponseReasoningItem::status
        ) -> OpenAI::Models::Beta::BetaResponseReasoningItem::status

        def initialize: (
          id: String,
          summary: ::Array[OpenAI::Beta::BetaResponseReasoningItem::Summary],
          ?agent: OpenAI::Beta::BetaResponseReasoningItem::Agent?,
          ?content: ::Array[OpenAI::Beta::BetaResponseReasoningItem::Content],
          ?encrypted_content: String?,
          ?status: OpenAI::Models::Beta::BetaResponseReasoningItem::status,
          ?type: :reasoning
        ) -> void

        def to_hash: -> {
          id: String,
          summary: ::Array[OpenAI::Beta::BetaResponseReasoningItem::Summary],
          type: :reasoning,
          agent: OpenAI::Beta::BetaResponseReasoningItem::Agent?,
          content: ::Array[OpenAI::Beta::BetaResponseReasoningItem::Content],
          encrypted_content: String?,
          status: OpenAI::Models::Beta::BetaResponseReasoningItem::status
        }

        type summary = { text: String, type: :summary_text }

        class Summary < OpenAI::Internal::Type::BaseModel
          attr_accessor text: String

          attr_accessor type: :summary_text

          def initialize: (text: String, ?type: :summary_text) -> void

          def to_hash: -> { text: String, type: :summary_text }
        end

        type agent = { agent_name: String }

        class Agent < OpenAI::Internal::Type::BaseModel
          attr_accessor agent_name: String

          def initialize: (agent_name: String) -> void

          def to_hash: -> { agent_name: String }
        end

        type content = { text: String, type: :reasoning_text }

        class Content < OpenAI::Internal::Type::BaseModel
          attr_accessor text: String

          attr_accessor type: :reasoning_text

          def initialize: (text: String, ?type: :reasoning_text) -> void

          def to_hash: -> { text: String, type: :reasoning_text }
        end

        type status = :in_progress | :completed | :incomplete

        module Status
          extend OpenAI::Internal::Type::Enum

          IN_PROGRESS: :in_progress
          COMPLETED: :completed
          INCOMPLETE: :incomplete

          def self?.values: -> ::Array[OpenAI::Models::Beta::BetaResponseReasoningItem::status]
        end
      end
    end
  end
end
