module OpenAI
  module Models
    module BetaResponseStatus = Beta::BetaResponseStatus

    module Beta
      type beta_response_status =
        :completed | :failed | :in_progress | :cancelled | :queued | :incomplete

      module BetaResponseStatus
        extend OpenAI::Internal::Type::Enum

        COMPLETED: :completed
        FAILED: :failed
        IN_PROGRESS: :in_progress
        CANCELLED: :cancelled
        QUEUED: :queued
        INCOMPLETE: :incomplete

        def self?.values: -> ::Array[OpenAI::Models::Beta::beta_response_status]
      end
    end
  end
end
