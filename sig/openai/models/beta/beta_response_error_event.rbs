module OpenAI
  module Models
    class BetaResponseErrorEvent = Beta::BetaResponseErrorEvent

    module Beta
      type beta_response_error_event =
        {
          code: String?,
          message: String,
          param: String?,
          sequence_number: Integer,
          type: :error,
          agent: OpenAI::Beta::BetaResponseErrorEvent::Agent?
        }

      class BetaResponseErrorEvent < OpenAI::Internal::Type::BaseModel
        attr_accessor code: String?

        attr_accessor message: String

        attr_accessor param: String?

        attr_accessor sequence_number: Integer

        attr_accessor type: :error

        attr_accessor agent: OpenAI::Beta::BetaResponseErrorEvent::Agent?

        def initialize: (
          code: String?,
          message: String,
          param: String?,
          sequence_number: Integer,
          ?agent: OpenAI::Beta::BetaResponseErrorEvent::Agent?,
          ?type: :error
        ) -> void

        def to_hash: -> {
          code: String?,
          message: String,
          param: String?,
          sequence_number: Integer,
          type: :error,
          agent: OpenAI::Beta::BetaResponseErrorEvent::Agent?
        }

        type agent = { agent_name: String }

        class Agent < OpenAI::Internal::Type::BaseModel
          attr_accessor agent_name: String

          def initialize: (agent_name: String) -> void

          def to_hash: -> { agent_name: String }
        end
      end
    end
  end
end
