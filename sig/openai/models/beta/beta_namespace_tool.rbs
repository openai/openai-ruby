module OpenAI
  module Models
    class BetaNamespaceTool = Beta::BetaNamespaceTool

    module Beta
      type beta_namespace_tool =
        {
          description: String,
          name: String,
          tools: ::Array[OpenAI::Models::Beta::BetaNamespaceTool::tool],
          type: :namespace
        }

      class BetaNamespaceTool < OpenAI::Internal::Type::BaseModel
        attr_accessor description: String

        attr_accessor name: String

        attr_accessor tools: ::Array[OpenAI::Models::Beta::BetaNamespaceTool::tool]

        attr_accessor type: :namespace

        def initialize: (
          description: String,
          name: String,
          tools: ::Array[OpenAI::Models::Beta::BetaNamespaceTool::tool],
          ?type: :namespace
        ) -> void

        def to_hash: -> {
          description: String,
          name: String,
          tools: ::Array[OpenAI::Models::Beta::BetaNamespaceTool::tool],
          type: :namespace
        }

        type tool =
          OpenAI::Beta::BetaNamespaceTool::Tool::Function
          | OpenAI::Beta::BetaCustomTool

        module Tool
          extend OpenAI::Internal::Type::Union

          type function =
            {
              name: String,
              type: :function,
              allowed_callers: ::Array[OpenAI::Models::Beta::BetaNamespaceTool::Tool::Function::allowed_caller]?,
              defer_loading: bool,
              description: String?,
              output_schema: ::Hash[Symbol, top]?,
              parameters: top?,
              strict: bool?
            }

          class Function < OpenAI::Internal::Type::BaseModel
            attr_accessor name: String

            attr_accessor type: :function

            attr_accessor allowed_callers: ::Array[OpenAI::Models::Beta::BetaNamespaceTool::Tool::Function::allowed_caller]?

            attr_reader defer_loading: bool?

            def defer_loading=: (bool) -> bool

            attr_accessor description: String?

            attr_accessor output_schema: ::Hash[Symbol, top]?

            attr_accessor parameters: top?

            attr_accessor strict: bool?

            def initialize: (
              name: String,
              ?allowed_callers: ::Array[OpenAI::Models::Beta::BetaNamespaceTool::Tool::Function::allowed_caller]?,
              ?defer_loading: bool,
              ?description: String?,
              ?output_schema: ::Hash[Symbol, top]?,
              ?parameters: top?,
              ?strict: bool?,
              ?type: :function
            ) -> void

            def to_hash: -> {
              name: String,
              type: :function,
              allowed_callers: ::Array[OpenAI::Models::Beta::BetaNamespaceTool::Tool::Function::allowed_caller]?,
              defer_loading: bool,
              description: String?,
              output_schema: ::Hash[Symbol, top]?,
              parameters: top?,
              strict: bool?
            }

            type allowed_caller = :direct | :programmatic

            module AllowedCaller
              extend OpenAI::Internal::Type::Enum

              DIRECT: :direct
              PROGRAMMATIC: :programmatic

              def self?.values: -> ::Array[OpenAI::Models::Beta::BetaNamespaceTool::Tool::Function::allowed_caller]
            end
          end

          def self?.variants: -> ::Array[OpenAI::Models::Beta::BetaNamespaceTool::tool]
        end
      end
    end
  end
end
