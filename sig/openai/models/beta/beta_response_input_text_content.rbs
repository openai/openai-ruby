module OpenAI
  module Models
    class BetaResponseInputTextContent = Beta::BetaResponseInputTextContent

    module Beta
      type beta_response_input_text_content =
        {
          text: String,
          type: :input_text,
          prompt_cache_breakpoint: OpenAI::Beta::BetaResponseInputTextContent::PromptCacheBreakpoint?
        }

      class BetaResponseInputTextContent < OpenAI::Internal::Type::BaseModel
        attr_accessor text: String

        attr_accessor type: :input_text

        attr_accessor prompt_cache_breakpoint: OpenAI::Beta::BetaResponseInputTextContent::PromptCacheBreakpoint?

        def initialize: (
          text: String,
          ?prompt_cache_breakpoint: OpenAI::Beta::BetaResponseInputTextContent::PromptCacheBreakpoint?,
          ?type: :input_text
        ) -> void

        def to_hash: -> {
          text: String,
          type: :input_text,
          prompt_cache_breakpoint: OpenAI::Beta::BetaResponseInputTextContent::PromptCacheBreakpoint?
        }

        type prompt_cache_breakpoint = { mode: :explicit }

        class PromptCacheBreakpoint < OpenAI::Internal::Type::BaseModel
          attr_accessor mode: :explicit

          def initialize: (?mode: :explicit) -> void

          def to_hash: -> { mode: :explicit }
        end
      end
    end
  end
end
