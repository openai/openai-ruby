module OpenAI
  module Models
    class BetaLocalSkill = Beta::BetaLocalSkill

    module Beta
      type beta_local_skill =
        { description: String, name: String, path: String }

      class BetaLocalSkill < OpenAI::Internal::Type::BaseModel
        attr_accessor description: String

        attr_accessor name: String

        attr_accessor path: String

        def initialize: (
          description: String,
          name: String,
          path: String
        ) -> void

        def to_hash: -> { description: String, name: String, path: String }
      end
    end
  end
end
