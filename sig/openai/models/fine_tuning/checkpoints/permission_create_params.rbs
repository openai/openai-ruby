module OpenAI
  module Models
    module FineTuning
      module Checkpoints
        type permission_create_params =
          { fine_tuned_model_checkpoint: String, project_ids: ::Array[String] }
          & OpenAI::Internal::Type::request_parameters

        class PermissionCreateParams < OpenAI::Internal::Type::BaseModel
          extend OpenAI::Internal::Type::RequestParameters::Converter
          include OpenAI::Internal::Type::RequestParameters

          attr_accessor fine_tuned_model_checkpoint: String

          attr_accessor project_ids: ::Array[String]

          def initialize: (
            fine_tuned_model_checkpoint: String,
            project_ids: ::Array[String],
            ?request_options: OpenAI::request_opts
          ) -> void

          def to_hash: -> {
            fine_tuned_model_checkpoint: String,
            project_ids: ::Array[String],
            request_options: OpenAI::RequestOptions
          }
        end
      end
    end
  end
end
