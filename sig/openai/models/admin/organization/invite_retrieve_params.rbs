module OpenAI
  module Models
    module Admin
      module Organization
        type invite_retrieve_params =
          { invite_id: String } & OpenAI::Internal::Type::request_parameters

        class InviteRetrieveParams < OpenAI::Internal::Type::BaseModel
          extend OpenAI::Internal::Type::RequestParameters::Converter
          include OpenAI::Internal::Type::RequestParameters

          attr_accessor invite_id: String

          def initialize: (
            invite_id: String,
            ?request_options: OpenAI::request_opts
          ) -> void

          def to_hash: -> {
            invite_id: String,
            request_options: OpenAI::RequestOptions
          }
        end
      end
    end
  end
end
