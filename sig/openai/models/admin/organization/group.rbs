module OpenAI
  module Models
    module Admin
      module Organization
        type group =
          {
            id: String,
            created_at: Integer,
            group_type: OpenAI::Models::Admin::Organization::Group::group_type,
            is_scim_managed: bool,
            name: String
          }

        class Group < OpenAI::Internal::Type::BaseModel
          attr_accessor id: String

          attr_accessor created_at: Integer

          attr_accessor group_type: OpenAI::Models::Admin::Organization::Group::group_type

          attr_accessor is_scim_managed: bool

          attr_accessor name: String

          def initialize: (
            id: String,
            created_at: Integer,
            group_type: OpenAI::Models::Admin::Organization::Group::group_type,
            is_scim_managed: bool,
            name: String
          ) -> void

          def to_hash: -> {
            id: String,
            created_at: Integer,
            group_type: OpenAI::Models::Admin::Organization::Group::group_type,
            is_scim_managed: bool,
            name: String
          }

          type group_type = :group | :tenant_group

          module GroupType
            extend OpenAI::Internal::Type::Enum

            GROUP: :group
            TENANT_GROUP: :tenant_group

            def self?.values: -> ::Array[OpenAI::Models::Admin::Organization::Group::group_type]
          end
        end
      end
    end
  end
end
