module OpenAI
  module Models
    module Admin
      module Organization
        class ProjectGroup = Projects::ProjectGroup

        module Projects
          type project_group =
            {
              created_at: Integer,
              group_id: String,
              group_name: String,
              group_type: OpenAI::Models::Admin::Organization::Projects::ProjectGroup::group_type,
              object: :"project.group",
              project_id: String
            }

          class ProjectGroup < OpenAI::Internal::Type::BaseModel
            attr_accessor created_at: Integer

            attr_accessor group_id: String

            attr_accessor group_name: String

            attr_accessor group_type: OpenAI::Models::Admin::Organization::Projects::ProjectGroup::group_type

            attr_accessor object: :"project.group"

            attr_accessor project_id: String

            def initialize: (
              created_at: Integer,
              group_id: String,
              group_name: String,
              group_type: OpenAI::Models::Admin::Organization::Projects::ProjectGroup::group_type,
              project_id: String,
              ?object: :"project.group"
            ) -> void

            def to_hash: -> {
              created_at: Integer,
              group_id: String,
              group_name: String,
              group_type: OpenAI::Models::Admin::Organization::Projects::ProjectGroup::group_type,
              object: :"project.group",
              project_id: String
            }

            type group_type = :group | :tenant_group

            module GroupType
              extend OpenAI::Internal::Type::Enum

              GROUP: :group
              TENANT_GROUP: :tenant_group

              def self?.values: -> ::Array[OpenAI::Models::Admin::Organization::Projects::ProjectGroup::group_type]
            end
          end
        end
      end
    end
  end
end
