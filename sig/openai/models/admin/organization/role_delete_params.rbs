module OpenAI
  module Models
    module Admin
      module Organization
        type role_delete_params =
          { role_id: String } & OpenAI::Internal::Type::request_parameters

        class RoleDeleteParams < OpenAI::Internal::Type::BaseModel
          extend OpenAI::Internal::Type::RequestParameters::Converter
          include OpenAI::Internal::Type::RequestParameters

          attr_accessor role_id: String

          def initialize: (
            role_id: String,
            ?request_options: OpenAI::request_opts
          ) -> void

          def to_hash: -> {
            role_id: String,
            request_options: OpenAI::RequestOptions
          }
        end
      end
    end
  end
end
