module OpenAI
  module Models
    module Admin
      module Organization
        type invite_delete_response =
          { id: String, deleted: bool, object: :"organization.invite.deleted" }

        class InviteDeleteResponse < OpenAI::Internal::Type::BaseModel
          attr_accessor id: String

          attr_accessor deleted: bool

          attr_accessor object: :"organization.invite.deleted"

          def initialize: (
            id: String,
            deleted: bool,
            ?object: :"organization.invite.deleted"
          ) -> void

          def to_hash: -> {
            id: String,
            deleted: bool,
            object: :"organization.invite.deleted"
          }
        end
      end
    end
  end
end
