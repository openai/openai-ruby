module OpenAI
  module Models
    module Responses
      type response_input_text_content =
        {
          text: String,
          type: :input_text,
          prompt_cache_breakpoint: OpenAI::Responses::ResponseInputTextContent::PromptCacheBreakpoint?
        }

      class ResponseInputTextContent < OpenAI::Internal::Type::BaseModel
        attr_accessor text: String

        attr_accessor type: :input_text

        attr_accessor prompt_cache_breakpoint: OpenAI::Responses::ResponseInputTextContent::PromptCacheBreakpoint?

        def initialize: (
          text: String,
          ?prompt_cache_breakpoint: OpenAI::Responses::ResponseInputTextContent::PromptCacheBreakpoint?,
          ?type: :input_text
        ) -> void

        def to_hash: -> {
          text: String,
          type: :input_text,
          prompt_cache_breakpoint: OpenAI::Responses::ResponseInputTextContent::PromptCacheBreakpoint?
        }

        type prompt_cache_breakpoint = { mode: :explicit }

        class PromptCacheBreakpoint < OpenAI::Internal::Type::BaseModel
          attr_accessor mode: :explicit

          def initialize: (?mode: :explicit) -> void

          def to_hash: -> { mode: :explicit }
        end
      end
    end
  end
end
