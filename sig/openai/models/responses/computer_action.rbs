module OpenAI
  module Models
    module Responses
      type computer_action =
        OpenAI::Responses::ComputerAction::Click
        | OpenAI::Responses::ComputerAction::DoubleClick
        | OpenAI::Responses::ComputerAction::Drag
        | OpenAI::Responses::ComputerAction::Keypress
        | OpenAI::Responses::ComputerAction::Move
        | OpenAI::Responses::ComputerAction::Screenshot
        | OpenAI::Responses::ComputerAction::Scroll
        | OpenAI::Responses::ComputerAction::Type
        | OpenAI::Responses::ComputerAction::Wait

      module ComputerAction
        extend OpenAI::Internal::Type::Union

        type click =
          {
            button: OpenAI::Models::Responses::ComputerAction::Click::button,
            type: :click,
            x: Integer,
            y_: Integer,
            keys: ::Array[String]?
          }

        class Click < OpenAI::Internal::Type::BaseModel
          attr_accessor button: OpenAI::Models::Responses::ComputerAction::Click::button

          attr_accessor type: :click

          attr_accessor x: Integer

          attr_accessor y_: Integer

          attr_accessor keys: ::Array[String]?

          def initialize: (
            button: OpenAI::Models::Responses::ComputerAction::Click::button,
            x: Integer,
            y_: Integer,
            ?keys: ::Array[String]?,
            ?type: :click
          ) -> void

          def to_hash: -> {
            button: OpenAI::Models::Responses::ComputerAction::Click::button,
            type: :click,
            x: Integer,
            y_: Integer,
            keys: ::Array[String]?
          }

          type button = :left | :right | :wheel | :back | :forward

          module Button
            extend OpenAI::Internal::Type::Enum

            LEFT: :left
            RIGHT: :right
            WHEEL: :wheel
            BACK: :back
            FORWARD: :forward

            def self?.values: -> ::Array[OpenAI::Models::Responses::ComputerAction::Click::button]
          end
        end

        type double_click =
          {
            keys: ::Array[String]?,
            type: :double_click,
            x: Integer,
            y_: Integer
          }

        class DoubleClick < OpenAI::Internal::Type::BaseModel
          attr_accessor keys: ::Array[String]?

          attr_accessor type: :double_click

          attr_accessor x: Integer

          attr_accessor y_: Integer

          def initialize: (
            keys: ::Array[String]?,
            x: Integer,
            y_: Integer,
            ?type: :double_click
          ) -> void

          def to_hash: -> {
            keys: ::Array[String]?,
            type: :double_click,
            x: Integer,
            y_: Integer
          }
        end

        type drag =
          {
            path: ::Array[OpenAI::Responses::ComputerAction::Drag::Path],
            type: :drag,
            keys: ::Array[String]?
          }

        class Drag < OpenAI::Internal::Type::BaseModel
          attr_accessor path: ::Array[OpenAI::Responses::ComputerAction::Drag::Path]

          attr_accessor type: :drag

          attr_accessor keys: ::Array[String]?

          def initialize: (
            path: ::Array[OpenAI::Responses::ComputerAction::Drag::Path],
            ?keys: ::Array[String]?,
            ?type: :drag
          ) -> void

          def to_hash: -> {
            path: ::Array[OpenAI::Responses::ComputerAction::Drag::Path],
            type: :drag,
            keys: ::Array[String]?
          }

          type path = { x: Integer, y_: Integer }

          class Path < OpenAI::Internal::Type::BaseModel
            attr_accessor x: Integer

            attr_accessor y_: Integer

            def initialize: (x: Integer, y_: Integer) -> void

            def to_hash: -> { x: Integer, y_: Integer }
          end
        end

        type keypress = { keys: ::Array[String], type: :keypress }

        class Keypress < OpenAI::Internal::Type::BaseModel
          attr_accessor keys: ::Array[String]

          attr_accessor type: :keypress

          def initialize: (keys: ::Array[String], ?type: :keypress) -> void

          def to_hash: -> { keys: ::Array[String], type: :keypress }
        end

        type move =
          { type: :move, x: Integer, y_: Integer, keys: ::Array[String]? }

        class Move < OpenAI::Internal::Type::BaseModel
          attr_accessor type: :move

          attr_accessor x: Integer

          attr_accessor y_: Integer

          attr_accessor keys: ::Array[String]?

          def initialize: (
            x: Integer,
            y_: Integer,
            ?keys: ::Array[String]?,
            ?type: :move
          ) -> void

          def to_hash: -> {
            type: :move,
            x: Integer,
            y_: Integer,
            keys: ::Array[String]?
          }
        end

        type screenshot = { type: :screenshot }

        class Screenshot < OpenAI::Internal::Type::BaseModel
          attr_accessor type: :screenshot

          def initialize: (?type: :screenshot) -> void

          def to_hash: -> { type: :screenshot }
        end

        type scroll =
          {
            scroll_x: Integer,
            scroll_y: Integer,
            type: :scroll,
            x: Integer,
            y_: Integer,
            keys: ::Array[String]?
          }

        class Scroll < OpenAI::Internal::Type::BaseModel
          attr_accessor scroll_x: Integer

          attr_accessor scroll_y: Integer

          attr_accessor type: :scroll

          attr_accessor x: Integer

          attr_accessor y_: Integer

          attr_accessor keys: ::Array[String]?

          def initialize: (
            scroll_x: Integer,
            scroll_y: Integer,
            x: Integer,
            y_: Integer,
            ?keys: ::Array[String]?,
            ?type: :scroll
          ) -> void

          def to_hash: -> {
            scroll_x: Integer,
            scroll_y: Integer,
            type: :scroll,
            x: Integer,
            y_: Integer,
            keys: ::Array[String]?
          }
        end

        type type_ = { text: String, type: :type }

        class Type < OpenAI::Internal::Type::BaseModel
          attr_accessor text: String

          attr_accessor type: :type

          def initialize: (text: String, ?type: :type) -> void

          def to_hash: -> { text: String, type: :type }
        end

        type wait = { type: :wait }

        class Wait < OpenAI::Internal::Type::BaseModel
          attr_accessor type: :wait

          def initialize: (?type: :wait) -> void

          def to_hash: -> { type: :wait }
        end

        def self?.variants: -> ::Array[OpenAI::Models::Responses::computer_action]
      end
    end
  end
end
