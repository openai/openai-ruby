        | OpenAI::Responses::ResponseErrorEvent
        | OpenAI::Responses::ResponseFileSearchCallCompletedEvent
        | OpenAI::Responses::ResponseFileSearchCallInProgressEvent
        | OpenAI::Responses::ResponseFileSearchCallSearchingEvent
