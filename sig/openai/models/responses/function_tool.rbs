module OpenAI
  module Models
    module Responses
      type function_tool =
        {
          name: String,
          parameters: ::Hash[Symbol, top]?,
          strict: bool?,
          type: :function,
          allowed_callers: ::Array[OpenAI::Models::Responses::FunctionTool::allowed_caller]?,
          defer_loading: bool,
          description: String?,
          output_schema: ::Hash[Symbol, top]?
        }

      class FunctionTool < OpenAI::Internal::Type::BaseModel
        attr_accessor name: String

        attr_accessor parameters: ::Hash[Symbol, top]?

        attr_accessor strict: bool?

        attr_accessor type: :function

        attr_accessor allowed_callers: ::Array[OpenAI::Models::Responses::FunctionTool::allowed_caller]?

        attr_reader defer_loading: bool?

        def defer_loading=: (bool) -> bool

        attr_accessor description: String?

        attr_accessor output_schema: ::Hash[Symbol, top]?

        def initialize: (
          name: String,
          parameters: ::Hash[Symbol, top]?,
          strict: bool?,
          ?allowed_callers: ::Array[OpenAI::Models::Responses::FunctionTool::allowed_caller]?,
          ?defer_loading: bool,
          ?description: String?,
          ?output_schema: ::Hash[Symbol, top]?,
          ?type: :function
        ) -> void

        def to_hash: -> {
          name: String,
          parameters: ::Hash[Symbol, top]?,
          strict: bool?,
          type: :function,
          allowed_callers: ::Array[OpenAI::Models::Responses::FunctionTool::allowed_caller]?,
          defer_loading: bool,
          description: String?,
          output_schema: ::Hash[Symbol, top]?
        }

        type allowed_caller = :direct | :programmatic

        module AllowedCaller
          extend OpenAI::Internal::Type::Enum

          DIRECT: :direct
          PROGRAMMATIC: :programmatic

          def self?.values: -> ::Array[OpenAI::Models::Responses::FunctionTool::allowed_caller]
        end
      end
    end
  end
end
